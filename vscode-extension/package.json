{
  "name": "algolab-vscode",
  "displayName": "AlgoLab",
  "description": "Coloration syntaxique et snippets pour le pseudo-code AlgoLab",
  "version": "0.1.0",
  "publisher": "algolab",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "icon": "images/algolab-full.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/adandeigor/AlgoLab.git"
  },
  "contributes": {
    "languages": [
      {
        "id": "algolab",
        "aliases": [
          "AlgoLab",
          "algolab"
        ],
        "extensions": [
          ".algo"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/algolab-icon.png",
          "dark": "./images/algolab-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "algolab",
        "scopeName": "source.algolab",
        "path": "./syntaxes/algolab.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "algolab",
        "path": "./snippets/algolab.code-snippets"
      }
    ]
  }
}
